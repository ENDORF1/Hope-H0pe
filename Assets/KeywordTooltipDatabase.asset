  Entries:
  - Keyword: "\u8FC7\u70ED"
    Explanation: "\u88AB\u8FC7\u70ED\u7684\u6A21\u5757\u4F1A\u7ACB\u523B\u76D6\u653E\uFF0C\u540C\u65F6\u4E0D\u518D\u53C2\u4E0E\u4E4B\u540E\u7684\u6218\u6597\u6D41\u7A0B\u3002"
  - Keyword: "\u65E0\u4EBA\u673A"
    Explanation: "\u65E0\u4EBA\u673A\u662F\u5438\u9644\u5728\u5DF2\u7FFB\u5F00\u6A21\u5757\u4E0A\u7684\u5C0F\u578B\u81EA\u5F8B\u673A\u68B0\u3002\u5B83\u4EEC\u62E5\u6709\u72EC\u7ACB\u7684\u8840\u91CF\uFF0C\u4F18\u5148\u53D7\u5230\u4F24\u5BB3\u3002\u7ED3\u7B97\u987A\u5E8F\u662F\u653B\u51FB-\u6CBB\u7597-\u5EFA\u9020\u3002"
  - Keyword: "\u51B7\u5374"
    Explanation: "\u6B63\u5728\u51B7\u5374\u7684\u6A21\u5757\u4E0D\u4F1A\u8FDB\u884C\u653B\u51FB\u3002\u8FD9\u4E2A\u6A21\u5757\u8FD8\u9700\u8981{cooldown}\u4E2A\u56DE\u5408\u8FDB\u884C\u51B7\u5374\u3002"
